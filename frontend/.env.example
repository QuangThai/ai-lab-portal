# Frontend environment template. Copy to frontend/.env (or .env.local) for local Next.js development.
# Docker images do not include .env* — inject vars at runtime (see docs/docker-deployment.md).
# Backend env lives in backend/.env (loaded by settings.py). Root .env is for Compose only.
# Do not commit real secrets.

# Internal FastAPI URL used by Next.js server components and server actions.
BACKEND_INTERNAL_URL=http://127.0.0.1:18000

# Better Auth configuration.
BETTER_AUTH_SECRET=replace-with-at-least-32-random-characters
BETTER_AUTH_URL=http://127.0.0.1:13000
BETTER_AUTH_TRUSTED_ORIGINS=http://127.0.0.1:13000
BETTER_AUTH_API_KEY=copy-from-better-auth-dashboard-or-leave-empty-for-local

# Auth/Postgres database URL used by Better Auth in the frontend app.
DATABASE_URL=postgresql://ai_lab:ai_lab_dev_password@localhost:15432/ai_lab_portal
AUTH_DATABASE_URL=postgresql://ai_lab:ai_lab_dev_password@localhost:15432/ai_lab_portal

# Must match backend AI_LAB_ADMIN_BOUNDARY_SECRET.
ADMIN_BOUNDARY_SECRET=replace-with-same-shared-server-secret-as-backend

# Optional public URL used for canonical/OpenGraph metadata.
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:13000

# Optional E2E/admin seed helpers.
E2E_PORT=13100
E2E_ADMIN_EMAIL=admin@example.com
E2E_ADMIN_PASSWORD=test-admin-password-123456
E2E_ADMIN_NAME=AI Lab Admin
ALLOW_ADMIN_SEED=0
